@page "/"
@inject EventApiClient ApiClient
@inject IDialogService DialogService
@inject LocationPreferenceService LocationPrefs
@inject IBrowserViewportService BrowserViewport

<PageTitle>Riftbound Eseménynaptár</PageTitle>

@if (_loading)
{
    <MudStack AlignItems="AlignItems.Center" Class="mt-16">
        <MudProgressCircular Indeterminate="true" Size="Size.Large" Color="Color.Primary" />
        <MudText Typo="Typo.body1" Class="mt-2">Események betöltése...</MudText>
    </MudStack>
}
else
{
    <MudPaper Class="pa-3 mb-3" Elevation="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudButton Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.MyLocation"
                       Size="Size.Small"
                       OnClick="OpenLocationPicker">
                Keresési terület
            </MudButton>
            <MudHidden Breakpoint="Breakpoint.SmAndDown">
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    @($"{_location.Lat:F4}°, {_location.Lng:F4}° — {_location.RadiusKm} km")
                </MudText>
            </MudHidden>
            <MudHidden Breakpoint="Breakpoint.MdAndUp">
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_location.RadiusKm km</MudText>
            </MudHidden>
            <MudSpacer />
            <MudText Typo="Typo.body2" Style="white-space: nowrap">@_items.Count esemény</MudText>
        </MudStack>
    </MudPaper>

    @if (_items.Count == 0)
    {
        <MudStack AlignItems="AlignItems.Center" Class="mt-16">
            <MudText Typo="Typo.h6" Color="Color.Secondary">Nincsenek események a megadott területen.</MudText>
        </MudStack>
    }
    else
    {
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudCalendar T="RiftboundCalendarItem"
                         Items="_items"
                         Culture="_culture"
                         View="CalendarView.Month"
                         FirstDayOfWeek="DayOfWeek.Monday"
                         ShowDay="false"
                         ShowWorkWeek="false"
                         Height="700"
                         ItemClicked="OnItemClicked"
                         MoreClicked="OnMoreClicked"
                         DateRangeChanged="OnDateRangeChanged" />
        </MudHidden>

        <MudHidden Breakpoint="Breakpoint.MdAndUp">
            @foreach (var group in UpcomingByDate)
            {
                <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mt-4 mb-1 px-1">
                    @FormatGroupDate(group.Key)
                </MudText>
                <MudDivider Class="mb-2" />
                @foreach (var item in group)
                {
                    <MudPaper Class="mb-2 pa-3" Elevation="1" Style="cursor: pointer"
                              @onclick="() => OnItemClicked(item)">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudStack Spacing="0" Style="flex: 1; min-width: 0">
                                <MudText Typo="Typo.body1" Style="font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis">
                                    @item.Text
                                </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @($"{item.Start:HH:mm} – {item.End:HH:mm} · {item.Event.LocationName}")
                                </MudText>
                            </MudStack>
                            <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Color="Color.Default" Size="Size.Small" />
                        </MudStack>
                    </MudPaper>
                }
            }
            @if (!UpcomingByDate.Any())
            {
                <MudStack AlignItems="AlignItems.Center" Class="mt-8">
                    <MudText Typo="Typo.body1" Color="Color.Secondary">Nincs közelgő esemény a területen.</MudText>
                </MudStack>
            }
        </MudHidden>
    }
}

@code {
    private static readonly CultureInfo _culture = new("hu-HU");

    private List<RiftboundCalendarItem> _allItems = [];
    private List<RiftboundCalendarItem> _items = [];
    private LocationPreference _location = LocationPreferenceService.Default;
    private bool _loading = true;

    private IEnumerable<IGrouping<DateTime, RiftboundCalendarItem>> UpcomingByDate =>
        _items
            .Where(i => i.Start.Date >= DateTime.Today)
            .OrderBy(i => i.Start)
            .GroupBy(i => i.Start.Date);

    protected override async Task OnInitializedAsync()
    {
        _location = await LocationPrefs.GetAsync();
        _allItems = await FetchItemsAsync();
        _items = GeoFilter.Apply(_allItems, _location.Lat, _location.Lng, _location.RadiusKm);
        _loading = false;
    }

    private async Task OpenLocationPicker()
    {
        var isMobile = await IsMobileAsync();
        var parameters = new DialogParameters<LocationPickerDialog>
        {
            { x => x.InitialLat, _location.Lat },
            { x => x.InitialLng, _location.Lng },
            { x => x.InitialRadiusKm, _location.RadiusKm }
        };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true,
            FullScreen = isMobile
        };
        var dialog = await DialogService.ShowAsync<LocationPickerDialog>(
            string.Empty, parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: LocationPreference newLocation })
        {
            _location = newLocation;
            await LocationPrefs.SaveAsync(newLocation);
            _items = GeoFilter.Apply(_allItems, _location.Lat, _location.Lng, _location.RadiusKm);
        }
    }

    private async Task OnDateRangeChanged()
    {
        if (_loading) return;
        _allItems = await FetchItemsAsync();
        _items = GeoFilter.Apply(_allItems, _location.Lat, _location.Lng, _location.RadiusKm);
    }

    private async Task<List<RiftboundCalendarItem>> FetchItemsAsync()
    {
        var events = await ApiClient.GetEventsAsync();
        return events.Select(e => new RiftboundCalendarItem
        {
            Start = e.StartDate.LocalDateTime,
            End = e.EndDate.LocalDateTime,
            Text = StatusPrefix(RegistrationStatusHelper.Get(e)) + e.Title,
            Event = e
        }).ToList();
    }

    private async Task OnMoreClicked(DateTime date)
    {
        var isMobile = await IsMobileAsync();
        var dayItems = _items
            .Where(i => i.Start.Date == date.Date)
            .OrderBy(i => i.Start)
            .ToList();

        var parameters = new DialogParameters<DayEventsDialog>
        {
            { x => x.Date, date },
            { x => x.Items, dayItems }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, CloseOnEscapeKey = true, FullScreen = isMobile };
        await DialogService.ShowAsync<DayEventsDialog>(string.Empty, parameters, options);
    }

    private string FormatGroupDate(DateTime date) =>
        date.ToString("yyyy. MMMM d., dddd", _culture);

    private static string StatusPrefix(RegistrationStatus status) => status switch
    {
        RegistrationStatus.Open   => "🟢 ",
        RegistrationStatus.Full   => "🔴 ",
        RegistrationStatus.Closed => "🔒 ",
        _                         => ""
    };

    private async Task OnItemClicked(RiftboundCalendarItem item)
    {
        var isMobile = await IsMobileAsync();
        var parameters = new DialogParameters<EventDetailDialog>
        {
            { x => x.Event, item.Event }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true, FullScreen = isMobile };
        await DialogService.ShowAsync<EventDetailDialog>(string.Empty, parameters, options);
    }

    private async Task<bool> IsMobileAsync()
    {
        var bp = await BrowserViewport.GetCurrentBreakpointAsync();
        return bp is Breakpoint.Xs or Breakpoint.Sm;
    }
}
