@inject FavoritesService FavoritesService
@inject EventApiClient ApiClient

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@Event.Title</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Filled.Casino" Color="Color.Primary" />
                <MudText>@Event.Format</MudText>
            </MudStack>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Filled.Store" Color="Color.Primary" />
                <MudText>@Event.LocationName</MudText>
            </MudStack>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Filled.Schedule" Color="Color.Primary" />
                <MudText>@FormatDateRange()</MudText>
            </MudStack>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@StatusIcon" Color="@StatusColor" />
                <MudText Color="@StatusColor">@StatusLabel</MudText>
            </MudStack>
            @if (Event.CostInCents.HasValue)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Color="Color.Primary" />
                    <MudText>@FormatPrice()</MudText>
                </MudStack>
            }
            @if (Event.Capacity.HasValue || Event.RegisteredCount.HasValue)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Primary" />
                    <MudText>@FormatAttendance()</MudText>
                </MudStack>
            }
            <iframe src="@MapUrl"
                    style="width:100%;height:180px;border:none;border-radius:4px;margin-top:4px"
                    loading="lazy" />
            <MudDivider Class="mt-2" />
            <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">Státusz változások</MudText>
            @if (_history.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">Még nem változott a státusz.</MudText>
            }
            else
            {
                <MudStack Spacing="1">
                    @foreach (var entry in _history)
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" Color="Color.Secondary" />
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @entry.ChangedAt.LocalDateTime.ToString("yyyy. MM. dd. HH:mm") —
                                @StatusLabelHu(entry.OldStatus) → @StatusLabelHu(entry.NewStatus)
                            </MudText>
                        </MudStack>
                    }
                </MudStack>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        @if (Event.StoreId is not null)
        {
            <MudTooltip Text="@(_isFavorite ? "Eltávolítás a kedvencekből" : "Helyszín hozzáadása a kedvencekhez")">
                <MudIconButton Icon="@(_isFavorite ? Icons.Material.Filled.Star : Icons.Material.Outlined.StarBorder)"
                               Color="@(_isFavorite ? Color.Warning : Color.Default)"
                               OnClick="ToggleFavorite" />
            </MudTooltip>
        }
        <MudSpacer />
        <MudButton Href="@Event.Url" Target="_blank" Color="Color.Primary" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.OpenInNew">
            Esemény oldala
        </MudButton>
        <MudButton OnClick="Close" Variant="Variant.Text">Bezárás</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public RiftboundEventDto Event { get; set; } = null!;

    private static readonly CultureInfo HunCulture = new("hu-HU");
    private bool _isFavorite;
    private IReadOnlyList<StatusHistoryEntryDto> _history = [];

    private RegistrationStatus Status => RegistrationStatusHelper.Get(Event);

    private string StatusIcon => Status switch
    {
        RegistrationStatus.Open   => Icons.Material.Filled.HowToReg,
        RegistrationStatus.Full   => Icons.Material.Filled.GroupOff,
        RegistrationStatus.Closed => Icons.Material.Filled.Lock,
        _                         => Icons.Material.Filled.Help
    };

    private Color StatusColor => Status switch
    {
        RegistrationStatus.Open   => Color.Success,
        RegistrationStatus.Full   => Color.Error,
        RegistrationStatus.Closed => Color.Error,
        _                         => Color.Default
    };

    private string StatusLabel => Status switch
    {
        RegistrationStatus.Open   => "Regisztráció nyitva",
        RegistrationStatus.Full   => "Betelt",
        RegistrationStatus.Closed => "Regisztráció még nem nyitott",
        _                         => ""
    };

    protected override async Task OnInitializedAsync()
    {
        var historyTask = ApiClient.GetEventHistoryAsync(Event.Id);
        if (Event.StoreId is not null)
            _isFavorite = await FavoritesService.IsFavoriteAsync(Event.StoreId);
        _history = await historyTask;
    }

    private async Task ToggleFavorite()
    {
        if (Event.StoreId is null) return;
        await FavoritesService.ToggleAsync(Event.StoreId, Event.LocationName);
        _isFavorite = !_isFavorite;
    }

    private string MapUrl => BuildMapUrl(Event.Latitude, Event.Longitude);

    private static string BuildMapUrl(double lat, double lng)
    {
        const double delta = 0.012;
        var west = (lng - delta).ToString("F6", CultureInfo.InvariantCulture);
        var south = (lat - delta).ToString("F6", CultureInfo.InvariantCulture);
        var east = (lng + delta).ToString("F6", CultureInfo.InvariantCulture);
        var north = (lat + delta).ToString("F6", CultureInfo.InvariantCulture);
        var latStr = lat.ToString("F6", CultureInfo.InvariantCulture);
        var lngStr = lng.ToString("F6", CultureInfo.InvariantCulture);
        return $"https://www.openstreetmap.org/export/embed.html?bbox={west},{south},{east},{north}&layer=mapnik&marker={latStr},{lngStr}";
    }

    private string FormatDateRange()
    {
        var start = Event.StartDate.LocalDateTime;
        var end = Event.EndDate.LocalDateTime;
        var date = start.ToString("yyyy. MMMM d., dddd", HunCulture);
        return $"{date}, {start:HH:mm}–{end:HH:mm}";
    }

    private string FormatPrice()
    {
        if (!Event.CostInCents.HasValue) return "";
        var amount = Event.CostInCents.Value / 100;
        var currency = Event.Currency ?? "HUF";
        return currency == "HUF"
            ? $"{amount:N0} Ft".Replace(",", " ")
            : $"{amount:N2} {currency}";
    }

    private string FormatAttendance()
    {
        if (Event.RegisteredCount.HasValue && Event.Capacity.HasValue)
            return $"{Event.RegisteredCount} / {Event.Capacity} jelentkező";
        if (Event.RegisteredCount.HasValue)
            return $"{Event.RegisteredCount} jelentkező";
        return $"Max. {Event.Capacity} fő";
    }

    private static string StatusLabelHu(string status) => status switch
    {
        "Open"   => "Nyitott",
        "Full"   => "Betelt",
        "Closed" => "Lezárt",
        _        => status
    };

    private void Close() => MudDialog.Close();
}
