@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary" Dense="true">
        <MudText Typo="Typo.h6" Class="mr-4">Riftbound Eseménynaptár</MudText>
        <MudSpacer />
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudButton Href="/" StartIcon="@Icons.Material.Filled.CalendarMonth"
                       Color="Color.Inherit" Variant="Variant.Text">Naptár</MudButton>
            <MudButton Href="/kedvencek" StartIcon="@Icons.Material.Filled.Star"
                       Color="Color.Inherit" Variant="Variant.Text">Kedvencek</MudButton>
        </MudHidden>
    </MudAppBar>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-4 mobile-bottom-safe">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div class="mobile-bottom-nav mud-elevation-8">
    <NavLink href="/" Match="NavLinkMatch.All" class="mobile-nav-item">
        <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" />
        <span>Naptár</span>
    </NavLink>
    <NavLink href="/kedvencek" class="mobile-nav-item">
        <MudIcon Icon="@Icons.Material.Filled.Star" />
        <span>Kedvencek</span>
    </NavLink>
</div>
